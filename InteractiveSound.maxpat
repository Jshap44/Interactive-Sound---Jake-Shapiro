            },
            {
                "box": {
                    "id": "obj-59",
                    "linecount": 6,
                    "maxclass": "comment",
                    "numinlets": 1,
                    "numoutlets": 0,
                    "patching_rect": [ 45.0, 798.5, 150.0, 87.0 ],
                    "text": "Large negative → moving in the same direction as gravity → downward\n\nLarge positive → moving against gravity → upward"
                }
            },
            {
                "box": {
                    "id": "obj-57",
                    "linecount": 5,
                    "maxclass": "comment",
                    "numinlets": 1,
                    "numoutlets": 0,
                    "patching_rect": [ 15.0, 649.0, 150.0, 87.0 ],
                    "text": "how much of my hand movement is in the same direction as gravity? - calculated with dot product\n"
                }
            },
            {
                "box": {
                    "id": "obj-55",
                    "linecount": 2,
                    "maxclass": "comment",
                    "numinlets": 1,
                    "numoutlets": 0,
                    "patching_rect": [ 15.0, 605.0, 150.0, 33.0 ],
                    "text": "Subtract gravity from raw values"
                }
            },
            {
                "box": {
                    "id": "obj-53",
                    "linecount": 4,
                    "maxclass": "comment",
                    "numinlets": 1,
                    "numoutlets": 0,
                    "patching_rect": [ 15.0, 540.0, 180.0, 60.0 ],
                    "text": "This gives you gx_bias gy_bias gz_bias — essentially a vector pointing in the direction gravity is pulling"
                }
            },
            {
                "box": {
                    "id": "obj-51",
                    "linecount": 4,
                    "maxclass": "comment",
                    "numinlets": 1,
                    "numoutlets": 0,
                    "patching_rect": [ 15.0, 467.0, 180.0, 60.0 ],
                    "text": "Because it changes slowly it captures the gravitational component (which is constant) while ignoring fast movements."
                }
            },
